<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      background: #f5f7fb;
    }

    .panel {
      border: 1px solid #e6e6e6;
      border-radius: 10px;
      transition: 0.2s;
    }

    .panel:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(0,0,0,0.08);
    }

    .title {
      font-weight: 700;
      letter-spacing: 0.4px;
    }

    .status-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      display: inline-block;
      margin-right: 6px;
    }

    .green { background: #28c76f; }
    .yellow { background: #ff9f43; }
    .blue { background: #00cfe8; }
  </style>
</head>

<body>

  <!-- NAVBAR -->
  <%- include('../partials/navbar') %>

  <div class="container py-4">

    <!-- HEADER -->
    <div class="mb-4">
      <h2 class="title">Centro de Control MULTICONFORT</h2>
      <p class="text-muted mb-0">
        Plataforma HVACR • BMS • IoT • IA Industrial
      </p>
    </div>

    <!-- STATUS BAR -->
    <div class="row g-3 mb-4">

      <div class="col-md-3">
        <div class="panel p-3 bg-white">
          <div class="text-muted small">Sistema HVACR</div>
          <div><span class="status-dot green"></span>Operativo</div>
        </div>
      </div>

      <div class="col-md-3">
        <div class="panel p-3 bg-white">
          <div class="text-muted small">BMS</div>
          <div><span class="status-dot green"></span>Online</div>
        </div>
      </div>

      <div class="col-md-3">
        <div class="panel p-3 bg-white">
          <div class="text-muted small">IoT</div>
          <div><span class="status-dot yellow"></span>Conectando</div>
        </div>
      </div>

      <div class="col-md-3">
        <div class="panel p-3 bg-white">
          <div class="text-muted small">IA</div>
          <div><span class="status-dot blue"></span>Activa</div>
        </div>
      </div>

    </div>

    <!-- MODULES -->
    <div class="row g-3">

      <div class="col-md-4">
        <div class="panel p-3 bg-white">
          <h6>HVACR</h6>
          <p class="text-muted mb-0">
            Control de climatización, ventilación y refrigeración industrial.
          </p>
        </div>
      </div>

      <div class="col-md-4">
        <div class="panel p-3 bg-white">
          <h6>BMS / Automatización</h6>
          <p class="text-muted mb-0">
            Gestión centralizada de edificios inteligentes.
          </p>
        </div>
      </div>

      <div class="col-md-4">
        <div class="panel p-3 bg-white">
          <h6>#multiIntelliAllConfort</h6>
          <p class="text-muted mb-0">
            Núcleo de inteligencia y expansión tecnológica.
          </p>
        </div>
      </div>

    </div>

    <!-- FOOTER -->
    <div class="text-center text-muted mt-5 small">
      MULTICONFORT IA • Versión 1.1 • Sistema Industrial Activo
    </div>

  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>